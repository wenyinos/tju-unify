<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tju.unify.conv.transaction.mapper.PostMapper">

    <insert id="insertPost" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO post (title,description,price,status,user_id)
        VALUES (#{title},#{description},#{price},#{status},#{userId})
    </insert>
</mapper>